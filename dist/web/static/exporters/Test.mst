{
  "ATLAS": {
    "SPRITES": [
      {{#rects}}
      {
        "SPRITE": {
          "name": "{{{name}}}",
          "x": {{frame.x}},
          "y": {{frame.y}},
          "w": {{frame.w}},
          "h": {{frame.h}},
          "frameWidth": {{sourceSize.w}},
          "frameHeight": {{sourceSize.h}},
          "frameX": -{{spriteSourceSize.x}},
          "frameY": -{{spriteSourceSize.y}},
          "rotated": {{rotated}}
        }
      }{{^last}},{{/last}}
      {{/rects}}
    ]
  },
  "meta": {
    "app": "{{{appInfo.url}}}",
    "version": "{{appInfo.version}}",
    "image": "{{config.imageFile}}",
    "format": "{{config.format}}",
    "size": {
      "w": {{config.imageWidth}},
      "h": {{config.imageHeight}}
    },
    "resolution": "1"
  }
}
